# Backend environment template
# Copy this file to backend/.env and fill real values. Do not commit backend/.env.

# Database shared by user-service, catalog-service, and commerce-service
ECOMMERCE_DB_URL=jdbc:postgresql://localhost:5432/ecommerce
ECOMMERCE_DB_USERNAME=postgres
ECOMMERCE_DB_PASSWORD=change-me

# Supabase project used by seed image upload scripts
SUPABASE_URL=https://your-project-ref.supabase.co
# Use service_role only on local/backend machines. Never expose it in mobile/frontend apps.
SUPABASE_SERVICE_ROLE_KEY=

# JWT shared by services
# Must be at least 32 bytes for HS256.
ECOMMERCE_JWT_SECRET=change-this-secret-to-at-least-32-bytes
ECOMMERCE_JWT_EXPIRATION_SECONDS=86400

# Service ports
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
CATALOG_SERVICE_PORT=8082
COMMERCE_SERVICE_PORT=8083

# Gateway upstream URLs
USER_SERVICE_URL=http://localhost:8081
CATALOG_SERVICE_URL=http://localhost:8082
COMMERCE_SERVICE_URL=http://localhost:8083

# Internal service clients
USER_SERVICE_BASE_URL=http://localhost:8081
CATALOG_SERVICE_BASE_URL=http://localhost:8082
COMMERCE_SERVICE_BASE_URL=http://localhost:8083

# RabbitMQ for order/payment notification events
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
EVENTS_RABBIT_EXCHANGE=ecommerce.events
EVENTS_RABBIT_NOTIFICATION_EMAIL_QUEUE=notification.email.order

# Mail for notification consumer
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Payment method flags
PAYMENT_COD_ENABLED=true
PAYMENT_EXPIRATION_SCAN_DELAY_MS=60000

# SePay integration
SEPAY_ENABLED=true
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=
SEPAY_CHECKOUT_ENDPOINT=https://pay.sepay.vn/v1/checkout/init
SEPAY_QR_ENDPOINT=https://qr.sepay.vn/img
SEPAY_SUCCESS_URL=
SEPAY_CANCEL_URL=
SEPAY_ERROR_URL=
SEPAY_WEBHOOK_SECRET=
SEPAY_PAYMENT_EXPIRE_MINUTES=15

# SePay QR beneficiary bank info
# Confirm bank short name with https://qr.sepay.vn/banks.json
SEPAY_BANK_NAME=
SEPAY_BANK_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
# Optional. Leave blank unless SePay/gateway/bank confirms a supported bank-app deeplink.
SEPAY_BANK_DEEP_LINK=

# VietQR.io quicklink/deeplink helper for SEPAY_QR UX.
# SePay remains the only provider that confirms payment via webhook/IPN.
VIETQR_ENABLED=true
VIETQR_QR_BASE_URL=https://img.vietqr.io/image
VIETQR_DEEPLINK_BASE_URL=https://dl.vietqr.io/pay
VIETQR_BANK_BIN=
VIETQR_BANK_CODE=
VIETQR_ACCOUNT_NO=
VIETQR_ACCOUNT_NAME=
VIETQR_TEMPLATE=compact2
VIETQR_DEEPLINK_ENABLED=false
# Optional VietQR app id, for example "mb" for MB Bank if verified against VietQR app deeplink list.
VIETQR_DEEPLINK_APP_CODE=
# Optional return URL. Can be a public HTTPS URL or app scheme if tested with target bank app.
VIETQR_RETURN_URL=

# Public base URL used in checkoutUrl returned to mobile.
# Local default goes through api-gateway. In production this must be public HTTPS.
APP_PUBLIC_BASE_URL=http://localhost:8080/api

# SePay method visibility
SEPAY_QR_ENABLED=true
SEPAY_CHECKOUT_ENABLED=true
SEPAY_CARD_ENABLED=true
SEPAY_APPLE_PAY_ENABLED=false
SEPAY_GOOGLE_PAY_ENABLED=false
